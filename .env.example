# Public URL — used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# Backend API base URL (e.g. http://localhost:8000)
NUXT_PUBLIC_API_BASE_URL=

# PartyKit host for realtime features (e.g. my-project.username.partykit.dev)
NUXT_PUBLIC_PARTYKIT_HOST=

# WhatsApp contact number (digits only, including country code, e.g. 6285111032928)
NUXT_PUBLIC_WHATSAPP_NUMBER=

# Midtrans payment gateway
# Set to PRODUCTION for live transactions, SANDBOX for testing
MIDTRANS_MODE=SANDBOX
MIDTRANS_CLIENT_KEY=
MIDTRANS_SANDBOX_CLIENT_KEY=

# NuxtHub — required for hub.blob and remote storage
NUXTHUB_ACCESS_TOKEN=
